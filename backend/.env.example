# Copy this file to .env (and load it however you prefer, e.g. django-environ,
# or just export these as shell variables) if you want to override defaults.

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOW_ALL=True

# Database - defaults to SQLite (db.sqlite3) if DB_ENGINE is unset.
# Set DB_ENGINE=mysql to use MySQL instead (also install mysqlclient).
# DB_ENGINE=mysql
# DB_NAME=complaint_system
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306
